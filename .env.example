# Football Prediction System - Mock 模式（无需任何 API Key！）
# 真实数据：填上 Key 并把 USE_MOCK_DATA=false 即可恢复

# ==================== API Keys（已禁用）===================
# FOOTBALL_API_KEY=your_key_here
# ODDS_API_KEY=your_key_here

# ==================== Mock 开关（默认开启）===================
USE_MOCK_DATA=true

# 其他配置保持不变
DATABASE_PATH=data/football.db
COMPETITIONS=PL,SA,BL1,FR1,IT1
DAYS_AHEAD=7
OUTPUT_DIR=site/data
MIN_EV_THRESHOLD=5
LOG_LEVEL=INFO
