# Football Prediction System - Safe Example (NO real keys)
# Production should use GitHub Actions Secrets, not committed .env files.

# Core football data
API_FOOTBALL_KEY=your_api_football_key_here
FOOTBALL_DATA_KEY=your_football_data_key_here
ODDS_API_KEY=your_odds_api_key_here
# optional aliases also supported:
# API_FOOTBALL_API_KEY=...
# FOOTBALL_DATA_API_KEY=...
# THE_ODDS_API_KEY=...

# Optional API overrides
API_FOOTBALL_BASE=https://v3.football.api-sports.io

# LLM relay (OpenAI-compatible)
OPENAI_BASE_URL=https://nan.meta-api.vip/v1
OPENAI_API_KEY=your_openai_relay_key_here
OPENAI_MODEL=gpt-5.4,gpt-5.3
# aliases supported: OPENAI_RELAY_URL / OPENAI_RELAY_KEY

# Gemini relay (OpenAI-compatible)
GEMINI_BASE_URL=https://once.novai.su/v1
GEMINI_API_KEY=your_gemini_relay_key_here
GEMINI_MODEL=gemini-3.1-pro,gemini-3.0-pro
# aliases supported: GEMINI_RELAY_URL / GEMINI_RELAY_KEY

# Runtime options
LOG_LEVEL=INFO
