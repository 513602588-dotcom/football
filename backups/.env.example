# Football Prediction System Configuration
# 足球预测系统配置文件

# ==================== API Keys ====================
# Football-data.org API
FOOTBALL_API_KEY=your_football_data_api_key_here

# The Odds API
ODDS_API_KEY=your_odds_api_key_here

# ==================== Database ====================
# SQLite数据库路径
DATABASE_PATH=data/football.db

# ==================== Model Configuration ====================
# 模型权重配置
MODEL_WEIGHTS_POISSON=0.20
MODEL_WEIGHTS_ELO=0.15
MODEL_WEIGHTS_XGBOOST=0.25
MODEL_WEIGHTS_DNN=0.25
MODEL_WEIGHTS_XG_MODEL=0.10
MODEL_WEIGHTS_HOME_BIAS=0.05

# XGBoost参数
XGBOOST_DEPTH=6
XGBOOST_LR=0.05
XGBOOST_ROUNDS=200

# DNN参数
DNN_HIDDEN_UNITS=256,128,64
DNN_EPOCHS=50
DNN_BATCH_SIZE=32

# Feature Engineering参数
FEATURE_LOOKBACK_DAYS=30
FEATURE_H2H_LIMIT=10

# ==================== Prediction Settings ====================
# 最小EV阈值 (百分比)
MIN_EV_THRESHOLD=5

# 最小置信度阈值 (百分比)
MIN_CONFIDENCE_THRESHOLD=50

# Kelly准则最大投注比例
KELLY_MAX_STAKE=0.30

# ==================== Data Collection ====================
# 主要联赛代码
COMPETITIONS=PL,SA,BL1,FR1,IT1

# 提前天数 (获取即将进行的比赛)
DAYS_AHEAD=7

# API缓存TTL (小时)
CACHE_TTL_HOURS=6

# ==================== Backtest Settings ====================
# 初始资金
INITIAL_BANKROLL=1000

# 固定赌注金额
FIXED_STAKE=10

# ==================== Output Settings ====================
# 输出目录
OUTPUT_DIR=site/data

# 导出格式
EXPORT_FORMAT=json

# ==================== Logging ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/prediction.log

# ==================== Performance ====================
# 最大内存使用量 (MB)
MAX_MEMORY_MB=2048

# 线程数
N_JOBS=-1

# ==================== Feature Flags ====================
# 启用历史数据加载
ENABLE_HISTORICAL_DATA=true

# 启用ML模型训练
ENABLE_ML_TRAINING=false

# 启用回测
ENABLE_BACKTESTING=true

# 启用可视化
ENABLE_VISUALIZATION=true

# ==================== Update Schedule ====================
# 自动更新间隔 (分钟)
AUTO_UPDATE_INTERVAL=360

# 启用自动更新
ENABLE_AUTO_UPDATE=false
